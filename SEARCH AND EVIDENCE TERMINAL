<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MATS TACTICAL - AMHERST/LYNCHBURG</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css" />
    
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
    <script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>

    <style>
        body, html { margin: 0; padding: 0; height: 100%; background: #000; overflow: hidden; font-family: sans-serif; }
        #map { width: 100%; height: 100%; }

        /* FLOATING ORANGE WIND ARROW */
        #wind-arrow-container {
            position: absolute; top: 80px; right: 20px; z-index: 1000;
            text-align: center; pointer-events: none;
        }
        #wind-arrow {
            font-size: 50px; color: #ff6600; /* Fluorescent Orange */
            text-shadow: 0 0 10px #ff6600, 0 0 20px #000;
            display: inline-block; transition: transform 0.5s ease-in-out;
        }
        .wind-label { color: #ff6600; font-weight: bold; font-size: 12px; background: rgba(0,0,0,0.6); padding: 2px 5px; }

        /* PERIMETER CORNER DOTS */
        .leaflet-editing-icon {
            background: #ff0000 !important; /* Large Red Dots for Corners */
            border: 2px solid #fff !important;
            width: 16px !important; height: 16px !important;
            margin-left: -8px !important; margin-top: -8px !important;
            border-radius: 50% !important;
        }

        /* HUD CONTROLS */
        .tactical-hud {
            position: absolute; bottom: 30px; width: 100%; z-index: 1001;
            display: flex; justify-content: center; gap: 10px; padding: 10px;
        }
        .hud-btn {
            background: #1a1a1a; color: #d4af37; border: 2px solid #d4af37;
            padding: 10px 15px; font-weight: bold; border-radius: 5px; cursor: pointer;
        }
        .reset-btn { background: #900; color: #fff; border-color: #fff; }

        /* RED FLAG MARKER */
        .red-flag { font-size: 24px; text-shadow: 2px 2px #000; }
    </style>
</head>
<body>

<div id="wind-arrow-container">
    <div id="wind-arrow">⬆</div>
    <div class="wind-label">WIND: NW 8 MPH</div>
</div>

<div id="map"></div>

<div class="tactical-hud">
    <button class="hud-btn" onclick="setMarker('LE')">BLUE LE</button>
    <button class="hud-btn" onclick="setMarker('K9')">LT BLUE K9</button>
    <button class="hud-btn" onclick="setMarker('FLAG')">🚩 RED FLAG</button>
    <button class="hud-btn reset-btn" onclick="resetPerimeter()">RESET PERIMETER/SEARCHERS</button>
</div>

<script>
    // Initialize Map with Address Search
    var map = L.map('map', { zoomControl: false }).setView([37.4137, -79.1422], 13);
    L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}').addTo(map);
    L.Control.geocoder({ defaultMarkGeocode: true }).addTo(map);

    var currentType = 'LE';
    var searchers = L.layerGroup().addTo(map);
    var drawnItems = new L.FeatureGroup().addTo(map);

    // Perimeter Draw Setup with Red Corner Logic
    var drawControl = new L.Control.Draw({
        edit: { featureGroup: drawnItems },
        draw: {
            polygon: { shapeOptions: { color: '#ff0000', weight: 4 } },
            polyline: false, circle: false, rectangle: true, marker: false
        }
    });
    map.addControl(drawControl);

    map.on(L.Draw.Event.CREATED, function (event) {
        drawnItems.addLayer(event.layer);
    });

    // Marker Selection and Removal Logic
    function setMarker(type) { currentType = type; }

    map.on('click', function(e) {
        let marker;
        if (currentType === 'FLAG') {
            marker = L.marker(e.latlng, {
                icon: L.divIcon({ className: 'red-flag', html: '🚩' })
            });
        } else if (currentType === 'K9') {
            marker = L.circleMarker(e.latlng, { radius: 10, fillColor: '#add8e6', color: '#0000ff', fillOpacity: 1 });
        } else {
            marker = L.circleMarker(e.latlng, { radius: 10, fillColor: '#0000ff', color: '#fff', fillOpacity: 1 });
        }
        
        // Remove individual searcher on click
        marker.on('dblclick', function() { searchers.removeLayer(marker); });
        searchers.addLayer(marker);
    });

    // Reset Function
    function resetPerimeter() {
        drawnItems.clearLayers();
        searchers.clearLayers();
    }

    // Dynamic Wind Arrow Rotation (Simulated NW)
    document.getElementById('wind-arrow').style.transform = 'rotate(-45deg)';
</script>

<div style="position: absolute; bottom: 5px; width: 100%; text-align: center; color: #d4af37; font-size: 10px; z-index: 2000;">
    App Created by Retired Deputy Sheriff EARL A. WOOD
</div>

</body>
</html>
