
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MATS TACTICAL COMMAND</title>
    
    <!-- Core Map Engine -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css" />
    
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
    <script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>

    <style>
        /* Force screen to fit mobile perfectly */
        body, html { margin: 0; padding: 0; height: 100%; background: #000; overflow: hidden; font-family: 'Arial Black', sans-serif; }
        #map { width: 100%; height: 100%; z-index: 10; }

        /* FLOATING WIND ARROW: FLUORESCENT ORANGE */
        #wind-box {
            position: absolute; top: 100px; right: 15px; z-index: 9999;
            text-align: center; pointer-events: none;
        }
        #wind-arrow {
            font-size: 80px; color: #ff6600; /* Fluorescent Orange */
            text-shadow: 0 0 20px #ff6600, 2px 2px 5px #000;
            display: inline-block; transform: rotate(-45deg);
        }
        .wind-txt { color: #ff6600; font-weight: bold; background: rgba(0,0,0,0.8); padding: 5px; border-radius: 5px; border: 1px solid #ff6600; }

        /* PERIMETER: LARGE RED CORNER DOTS */
        .leaflet-editing-icon {
            background: #ff0000 !important; border: 3px solid #fff !important;
            width: 30px !important; height: 30px !important;
            margin-left: -15px !important; margin-top: -15px !important;
            border-radius: 50% !important; box-shadow: 0 0 20px #f00 !important;
        }

        /* LIVE GPS DOT: BLUE & WHITE FLASHING */
        @keyframes pulse-white {
            0% { box-shadow: 0 0 0 0px rgba(255, 255, 255, 1); }
            70% { box-shadow: 0 0 0 25px rgba(255, 255, 255, 0); }
            100% { box-shadow: 0 0 0 0px rgba(255, 255, 255, 0); }
        }
        .gps-live {
            width: 25px; height: 25px; background: #0000ff; border: 5px solid #ffffff;
            border-radius: 50%; animation: pulse-white 1.2s infinite; z-index: 10000;
        }

        /* TACTICAL COMMAND BAR - FORCED VISIBILITY */
        .command-bar {
            position: absolute; bottom: 30px; left: 0; width: 100%;
            z-index: 99999; display: flex; justify-content: center; gap: 5px; padding: 10px;
            background: rgba(0,0,0,0.5);
        }
        .cmd-btn {
            background: #111; color: #d4af37; border: 3px solid #d4af37;
            padding: 18px 10px; font-weight: bold; border-radius: 8px; cursor: pointer;
            font-size: 12px; text-transform: uppercase; flex-grow: 1;
            box-shadow: 0px 5px 15px rgba(0,0,0,0.5);
        }
        .btn-perimeter { background: #400; border-color: #f00; color: #fff; }
        .btn-reset { background: #800; border-color: #fff; color: #fff; }

        /* RED FLAG PROPERTY ICON */
        .prop-flag { font-size: 45px; filter: drop-shadow(3px 3px 3px #000); }
    </style>
</head>
<body>

<div id="map"></div>

<!-- FORCED UI ELEMENTS -->
<div id="wind-box">
    <div id="wind-arrow">⬆</div><br>
    <span class="wind-txt">WIND: NW 8MPH</span>
</div>

<div class="command-bar">
    <button class="cmd-btn btn-perimeter" onclick="drawSector()">DRAW PERIMETER</button>
    <button class="cmd-btn" onclick="setTMode('LE')">BLUE LE</button>
    <button class="cmd-btn" onclick="setTMode('K9')">K9 UNIT</button>
    <button class="cmd-btn" onclick="setTMode('FLAG')">🚩 PROPERTY</button>
    <button class="cmd-btn btn-reset" onclick="clearField()">RESET</button>
</div>

<script>
    // Initialize Map with Address Search
    var map = L.map('map', { zoomControl: false }).setView([37.4137, -79.1422], 14);
    L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}').addTo(map);
    L.Control.geocoder({ position: 'topleft' }).addTo(map);

    var searchers = L.layerGroup().addTo(map);
    var perimeters = new L.FeatureGroup().addTo(map);
    var tMode = 'LE';

    // 1. LIVE GPS (Blue/White Dot)
    var userPos = null;
    map.locate({ watch: true, enableHighAccuracy: true });
    map.on('locationfound', function(e) {
        if (!userPos) {
            userPos = L.marker(e.latlng, { icon: L.divIcon({ className: 'gps-live' }) }).addTo(map);
            map.setView(e.latlng, 17);
        } else {
            userPos.setLatLng(e.latlng);
        }
    });

    // 2. PERIMETER DRAW (Red Corners)
    var polyDraw = new L.Draw.Polygon(map, {
        shapeOptions: { color: '#ff0000', weight: 6, fillOpacity: 0.3 }
    });
    window.drawSector = function() { polyDraw.enable(); };
    map.on(L.Draw.Event.CREATED, function (e) { perimeters.addLayer(e.layer); });

    // 3. SEARCHER ADD/DELETE
    window.setTMode = function(mode) { tMode = mode; };
    map.on('click', function(e) {
        var marker;
        if (tMode === 'FLAG') {
            marker = L.marker(e.latlng, { icon: L.divIcon({ className: 'prop-flag', html: '🚩', iconSize: [50,50], iconAnchor: [25,50] }) });
        } else if (tMode === 'K9') {
            marker = L.circleMarker(e.latlng, { radius: 18, fillColor: '#add8e6', color: '#0000ff', weight: 5, fillOpacity: 1 });
        } else {
            marker = L.circleMarker(e.latlng, { radius: 18, fillColor: '#0000ff', color: '#fff', weight: 5, fillOpacity: 1 });
        }

        // Tap dot again to REMOVE/DELETE
        marker.on('click', function() { searchers.removeLayer(marker); });
        searchers.addLayer(marker);
    });

    // 4. GLOBAL RESET
    window.clearField = function() {
        if(confirm("WIPE ENTIRE SCENE?")) {
            perimeters.clearLayers();
            searchers.clearLayers();
        }
    };
</script>

<div style="position: absolute; bottom: 5px; width: 100%; text-align: center; color: #d4af37; font-size: 10px; z-index: 999999;">
    Tactical Terminal - Retired Deputy Sheriff EARL A. WOOD
</div>

</body>
</html>
