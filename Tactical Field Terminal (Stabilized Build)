
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MATS TACTICAL COMMAND</title>
    
    <!-- Mandatory Map Assets -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css" />
    
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
    <script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>

    <style>
        body, html { margin: 0; padding: 0; height: 100%; background: #000; overflow: hidden; font-family: 'Arial Black', sans-serif; }
        #map { width: 100%; height: 100%; z-index: 1; }

        /* FLUORESCENT ORANGE WIND ARROW */
        #wind-box {
            position: absolute; top: 110px; right: 15px; z-index: 9999;
            text-align: center; pointer-events: none;
        }
        #wind-arrow {
            font-size: 80px; color: #ff6600; 
            text-shadow: 0 0 20px #ff6600, 2px 2px 5px #000;
            display: inline-block; transform: rotate(-45deg);
        }
        .wind-txt { color: #ff6600; font-weight: bold; background: rgba(0,0,0,0.8); padding: 5px; border-radius: 5px; border: 2px solid #ff6600; }

        /* PERIMETER: LARGE RED CORNER DOTS */
        .leaflet-editing-icon {
            background: #ff0000 !important; border: 3px solid #fff !important;
            width: 32px !important; height: 32px !important;
            margin-left: -16px !important; margin-top: -16px !important;
            border-radius: 50% !important; box-shadow: 0 0 20px #f00 !important;
        }

        /* LIVE GPS DOT: BLUE & WHITE FLASHING */
        @keyframes pulse-gps {
            0% { box-shadow: 0 0 0 0px rgba(255, 255, 255, 1); }
            70% { box-shadow: 0 0 0 25px rgba(255, 255, 255, 0); }
            100% { box-shadow: 0 0 0 0px rgba(255, 255, 255, 0); }
        }
        .gps-live {
            width: 26px; height: 26px; background: #0000ff; border: 5px solid #ffffff;
            border-radius: 50%; animation: pulse-gps 1.2s infinite; z-index: 10000;
        }

        /* COMMAND HUD (FORCED TOP LAYER) */
        .tactical-hud {
            position: absolute; bottom: 25px; left: 0; width: 100%;
            z-index: 99999; display: flex; flex-wrap: wrap; justify-content: center; gap: 6px; padding: 15px;
            background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
        }
        .t-btn {
            background: #111; color: #d4af37; border: 3px solid #d4af37;
            padding: 18px 12px; font-weight: bold; border-radius: 10px; cursor: pointer;
            font-size: 13px; text-transform: uppercase; min-width: 90px;
        }
        .btn-draw { background: #500; border-color: #f00; color: #fff; }
        .btn-reset { background: #900; border-color: #fff; color: #fff; }

        /* ADDRESS BOX ADJUSTMENT */
        .leaflet-control-geocoder { margin-top: 20px !important; margin-left: 20px !important; scale: 1.2; }

        /* FLAG ICON */
        .flag-icon { font-size: 48px; filter: drop-shadow(4px 4px 4px #000); }
    </style>
</head>
<body>

<div id="map"></div>

<!-- FORCED INTERFACE OVERLAY -->
<div id="wind-box">
    <div id="wind-arrow">⬆</div><br>
    <span class="wind-txt">WIND: NW 8MPH</span>
</div>

<div class="tactical-hud">
    <button class="t-btn btn-draw" onclick="activateDraw()">PERIMETER</button>
    <button class="t-btn" onclick="setMode('LE')">BLUE LE</button>
    <button class="t-btn" onclick="setMode('K9')">K9 UNIT</button>
    <button class="t-btn" onclick="setMode('FLAG')">🚩 FLAG</button>
    <button class="t-btn btn-reset" onclick="resetAll()">RESET ALL</button>
</div>

<script>
    // 1. Setup Map & Address Search
    var map = L.map('map', { zoomControl: false }).setView([37.4137, -79.1422], 14);
    L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}').addTo(map);
    
    // Address Box (Top Left)
    var geocoder = L.Control.geocoder({ position: 'topleft', placeholder: 'ENTER ADDRESS...' }).addTo(map);

    var searchers = L.layerGroup().addTo(map);
    var perimeterLayer = new L.FeatureGroup().addTo(map);
    var activeMode = 'LE';

    // 2. LIVE GPS DOT (Blue and White)
    var locationMarker = null;
    map.locate({ watch: true, enableHighAccuracy: true });
    map.on('locationfound', function(e) {
        if (!locationMarker) {
            locationMarker = L.marker(e.latlng, { icon: L.divIcon({ className: 'gps-live' }) }).addTo(map);
            map.setView(e.latlng, 17);
        } else {
            locationMarker.setLatLng(e.latlng);
        }
    });

    // 3. PERIMETER DRAW (Red Large Dots)
    var polygonTool = new L.Draw.Polygon(map, {
        shapeOptions: { color: '#ff0000', weight: 6, fillOpacity: 0.2 }
    });
    window.activateDraw = function() { polygonTool.enable(); };
    map.on(L.Draw.Event.CREATED, function (e) { perimeterLayer.addLayer(e.layer); });

    // 4. ADD & REMOVE SEARCHERS
    window.setMode = function(m) { activeMode = m; };
    map.on('click', function(e) {
        var mkr;
        if (activeMode === 'FLAG') {
            mkr = L.marker(e.latlng, { icon: L.divIcon({ className: 'flag-icon', html: '🚩', iconSize: [50,50], iconAnchor: [25,50] }) });
        } else if (activeMode === 'K9') {
            mkr = L.circleMarker(e.latlng, { radius: 20, fillColor: '#add8e6', color: '#00f', weight: 5, fillOpacity: 1 });
        } else {
            mkr = L.circleMarker(e.latlng, { radius: 20, fillColor: '#00f', color: '#fff', weight: 5, fillOpacity: 1 });
        }
        
        // Tap any dot/flag to DELETE/REMOVE
        mkr.on('click', function() { searchers.removeLayer(mkr); });
        searchers.addLayer(mkr);
    });

    // 5. RESET FUNCTION
    window.resetAll = function() {
        if(confirm("CLEAR ALL MISSION DATA?")) {
            perimeterLayer.clearLayers();
            searchers.clearLayers();
        }
    };
</script>

<div style="position: absolute; bottom: 5px; width: 100%; text-align: center; color: #d4af37; font-size: 11px; z-index: 100000;">
    RETIRED DEPUTY SHERIFF EARL A. WOOD - TACTICAL TERMINAL
</div>

</body>
</html>
